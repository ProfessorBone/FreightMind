# TRIL Environment Configuration
# Copy this file to ~/.tril.env and customize for your deployment

# Service Mode Configuration
# Options: stub (default), nominatim, graphhopper
TRIL_GEOCODER_MODE=stub
TRIL_ROUTER_MODE=stub

# Service Endpoints
# Update these when running live services
TRIL_NOMINATIM_URL=http://127.0.0.1:8080
TRIL_GRAPHHOPPER_URL=http://127.0.0.1:8989

# GraphHopper Configuration
# Profile should match your GraphHopper setup
TRIL_GRAPHHOPPER_PROFILE=truck

# HTTP Client Configuration
TRIL_HTTP_USER_AGENT="TRIL/1.0 (Hannibal)"
TRIL_HTTP_TIMEOUT=30

# Logging Level (optional)
# Options: DEBUG, INFO, WARNING, ERROR
TRIL_LOG_LEVEL=INFO

# Data Directory (optional)
# Defaults to tril/data
# TRIL_DATA_DIR=/path/to/custom/data

# Output Directory (optional)  
# Defaults to tril/out
# TRIL_OUTPUT_DIR=/path/to/custom/output

# Production Mode (optional)
# Set to 'true' for stricter validation
# TRIL_PRODUCTION_MODE=false

# MCP Integration (optional)
# Set when integrating with OpenClaw
# MCP_SERVER_URL=http://localhost:3000
# MCP_AUTH_TOKEN=your-token-here