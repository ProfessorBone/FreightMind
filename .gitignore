# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# TRIL generated outputs
tril/out/*.gpx
tril/out/*.json
!tril/out/.gitkeep

# TRIL logs
tril/logs/*.jsonl
tril/logs/*.log
!tril/logs/.gitkeep

# OSM data (large files — download locally)
tril/data/extracts/*.osm.pbf
tril/data/graphhopper/

# Eval results (regenerated on each run)
tril/eval_results.json
tril/tests/production_validation_results.json

# Environment
.env
*.env.local
.tril.env

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Claude Code settings
.claude/
